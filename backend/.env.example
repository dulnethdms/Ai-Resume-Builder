# MongoDB
# Local development:
MONGODB_URI=mongodb://127.0.0.1:27017/ai-resume-builder

# MongoDB Atlas example:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/ai-resume-builder?retryWrites=true&w=majority

# Auth
JWT_SECRET=change-me-in-production

# App
PORT=5000

# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,http://127.0.0.1:5500
