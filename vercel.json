{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/", "destination": "/frontend/index.html" },
    { "source": "/index.html", "destination": "/frontend/index.html" },
    { "source": "/login.html", "destination": "/frontend/login.html" },
    { "source": "/signup.html", "destination": "/frontend/signup.html" },
    { "source": "/dashboard.html", "destination": "/frontend/dashboard.html" },
    { "source": "/create-cv.html", "destination": "/frontend/create-cv.html" },
    { "source": "/404.html", "destination": "/frontend/404.html" },
    { "source": "/favicon.ico", "destination": "/frontend/favicon.ico" },
    { "source": "/assets/(.*)", "destination": "/frontend/assets/$1" }
  ]
}
